# backend/main.py
from fastapi import FastAPI, Depends, HTTPException
from sqlalchemy import create_engine
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker, Session
import redis
from typing import Optional
import asyncio

app = FastAPI(title="Hospital Management System")
Base = declarative_base()

# Database setup
DATABASE_URL = os.getenv("DATABASE_URL")
engine = create_engine(DATABASE_URL)
SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)

# Redis for caching and real-time updates
redis_client = redis.from_url(os.getenv("REDIS_URL"))

# Models
from sqlalchemy import Column, Integer, String, DateTime, Boolean, ForeignKey, Text
from datetime import datetime

class Patient(Base):
    __tablename__ = "patients"
    
    id = Column(Integer, primary_key=True, index=True)
    abha_id = Column(String, unique=True, index=True)
    name = Column(String)
    age = Column(Integer)
    gender = Column(String)
    phone = Column(String)
    address = Column(Text)
    created_at = Column(DateTime, default=datetime.utcnow)
    
class Doctor(Base):
    __tablename__ = "doctors"
    
    id = Column(Integer, primary_key=True, index=True)
    name = Column(String)
    specialization = Column(String)
    license_no = Column(String, unique=True)
    available = Column(Boolean, default=True)
    
class Bed(Base):
    __tablename__ = "beds"
    
    id = Column(Integer, primary_key=True, index=True)
    bed_number = Column(String, unique=True)
    ward_type = Column(String)  # ICU, General, Private
    occupied = Column(Boolean, default=False)
    patient_id = Column(Integer, ForeignKey("patients.id"), nullable=True)

class Appointment(Base):
    __tablename__ = "appointments"
    
    id = Column(Integer, primary_key=True, index=True)
    patient_id = Column(Integer, ForeignKey("patients.id"))
    doctor_id = Column(Integer, ForeignKey("doctors.id"))
    appointment_time = Column(DateTime)
    status = Column(String, default="scheduled")
    type = Column(String)  # OPD, Emergency, Telemedicine

# API Endpoints
@app.post("/api/patients")
async def create_patient(patient_data: dict, db: Session = Depends(get_db)):
    patient = Patient(**patient_data)
    db.add(patient)
    db.commit()
    
    # Sync for offline capability
    redis_client.set(f"patient:{patient.id}", json.dumps(patient_data))
    
    return {"id": patient.id, "abha_id": patient.abha_id}

@app.get("/api/beds/availability")
async def get_bed_availability(db: Session = Depends(get_db)):
    beds = db.query(Bed).filter(Bed.occupied == False).all()
    return {"available_beds": len(beds), "details": beds}

@app.post("/api/emergency")
