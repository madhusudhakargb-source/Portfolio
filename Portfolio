# backend/ai_services.py
import torch
from transformers import pipeline
import speech_recognition as sr
from gtts import gTTS

class HospitalAIService:
    def __init__(self):
        self.triage_model = self.load_triage_model()
        self.telugu_stt = pipeline("automatic-speech-recognition", model="vasista22/whisper-telugu")
        
    async def ai_triage(self, symptoms: dict) -> str:
        # Emergency severity classification
        features = self.extract_features(symptoms)
        severity = self.triage_model.predict(features)
        
        if severity > 0.8:
            return "CRITICAL"
        elif severity > 0.5:
            return "URGENT"
        else:
            return "NORMAL"
    
    async def telugu_voice_processing(self, audio_file: bytes) -> dict:
        # Convert Telugu speech to text
        text = self.telugu_stt(audio_file)
        
        # Process medical query
        response = await self.process_medical_query(text)
        
        # Convert response back to Telugu speech
        tts = gTTS(text=response, lang='te')
        audio_response = tts.save("response.mp3")
        
        return {"text": response, "audio": audio_response}
