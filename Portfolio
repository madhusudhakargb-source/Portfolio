// Offline Sync Component
const OfflineSync: React.FC = () => {
  useEffect(() => {
    // IndexedDB for offline storage
    const db = await openDB('hospital-db', 1, {
      upgrade(db) {
        db.createObjectStore('patients');
        db.createObjectStore('appointments');
        db.createObjectStore('prescriptions');
      }
    });

    // Sync when online
    window.addEventListener('online', async () => {
      const offlineData = await db.getAll('patients');
      offlineData.forEach(async (patient) => {
        await syncPatientData(patient);
      });
    });
  }, []);

  return null;
};
